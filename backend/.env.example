# Application
APP_NAME=perdin-test-backend
APP_ENV=development        # development | staging | production
APP_PORT=8080
APP_REQUESTTIMEOUT=20
APP_READTIMEOUT=15
APP_WRITETIMEOUT=30
APP_IDLETIMEOUT=60

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=sgp_db
DATABASE_MAXIDLECONN=2
DATABASE_SSLMODE=disable

# JWT
JWT_SECRETKEY=your_secret_key
JWT_EXPIREDURATION=24      # in hours